{
  "name": "react-plotly.js",
  "version": "3.0.0",
  "license": "MIT",
  "description": "A plotly.js react component from Plotly",
  "author": "Plotly, Inc.",
  "type": "commonjs",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "unpkg": "./dist/create-plotly-component.min.js",
  "jsdelivr": "./dist/create-plotly-component.min.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./factory": {
      "import": "./dist/factory.mjs",
      "require": "./dist/factory.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plotly/react-plotly.js.git"
  },
  "bugs": {
    "url": "https://github.com/plotly/react-plotly.js/issues"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "lint": "prettier --trailing-comma es5 --write \"src/**/*.js\" && eslint src",
    "test": "npm run lint && jest",
    "watch-test": "jest --watch",
    "watch": "tsup --watch"
  },
  "keywords": [
    "graphing",
    "plotting",
    "data",
    "visualization",
    "plotly",
    "react"
  ],
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.19.0",
    "@babel/eslint-parser": "^7.29.0",
    "@babel/preset-env": "^7.19.0",
    "@babel/preset-react": "^7.18.6",
    "@eslint/js": "^9.39.0",
    "@testing-library/react": "^16.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.0",
    "event-emitter": "^0.3.5",
    "globals": "^17.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^2.0.19",
    "onetime": "^5.1.2",
    "plotly.js": "^3.0.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^3.0.2",
    "semver": "^7.3.7",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "plotly.js": ">=3.0.0",
    "react": "^18.0.0 || ^19.0.0"
  }
}
